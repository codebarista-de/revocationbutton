{% block codebarista_revocation_form %}
<div id="codebarista-revocation-form" class="cms-element-form cms-block cb-revocation-form">
    <form action="{{ path('frontend.codebarista.revocation.request') }}"
          method="post"
          class="needs-validation"
          data-form-validation="true"
          data-form-csrf-handler="true"
          data-form-ajax-submit="true"
          data-form-ajax-submit-options='{"replaceSelectors": false, "scrollToAlert": true, "resetSubmittedForm": true}'>

        {% if not feature('v6.5.0.0') %}
            {% sw_include '@Storefront/storefront/includes/revocationform_csrf.html.twig' %}
        {% endif %}

        <div class="form-alert"></div>

        <div class="row g-2">
            <div class="form-group col-md-6">
                <label class="form-label" for="codebarista-revocation-firstName">
                    {{ 'codebaristaRevocationRequest.firstNameLabel'|trans|sw_sanitize }}
                </label>
                <input type="text"
                       class="form-control"
                       id="codebarista-revocation-firstName"
                       name="firstName"
                       autocomplete="section-personal given-name"
                       placeholder="{{ 'codebaristaRevocationRequest.firstNamePlaceholder'|trans|sw_sanitize }}"
                       maxlength="255">
            </div>

            <div class="form-group col-md-6">
                <label class="form-label" for="codebarista-revocation-lastName">
                    {{ 'codebaristaRevocationRequest.lastNameLabel'|trans|sw_sanitize }}
                </label>
                <input type="text"
                       class="form-control"
                       id="codebarista-revocation-lastName"
                       name="lastName"
                       autocomplete="section-personal family-name"
                       placeholder="{{ 'codebaristaRevocationRequest.lastNamePlaceholder'|trans|sw_sanitize }}"
                       maxlength="255">
            </div>

            <div class="form-group col-md-12">
                <label class="form-label" for="codebarista-revocation-email">
                    {{ 'codebaristaRevocationRequest.emailLabel'|trans|sw_sanitize }}
                    <span class="text-danger">*</span>
                </label>
                <input type="email"
                       class="form-control"
                       id="codebarista-revocation-email"
                       name="email"
                       required="required"
                       autocomplete="email"
                       placeholder="{{ 'codebaristaRevocationRequest.emailPlaceholder'|trans|sw_sanitize }}"
                       maxlength="320">
            </div>

            <div class="form-group col-md-12">
                <label class="form-label" for="codebarista-revocation-contractNumber">
                    {{ 'codebaristaRevocationRequest.contractNumberLabel'|trans|sw_sanitize }}
                    <span class="text-danger">*</span>
                </label>
                <input type="text"
                       class="form-control"
                       id="codebarista-revocation-contractNumber"
                       name="contractNumber"
                       required="required"
                       placeholder="{{ 'codebaristaRevocationRequest.contractNumberPlaceholder'|trans|sw_sanitize }}"
                       maxlength="255">
                <small class="form-text text-muted">
                    {{ 'codebaristaRevocationRequest.contractNumberHelp'|trans|sw_sanitize }}
                </small>
            </div>

            <div class="form-group col-md-12">
                <label class="form-label" for="codebarista-revocation-comment">
                    {{ 'codebaristaRevocationRequest.commentLabel'|trans|sw_sanitize }}
                </label>
                <textarea class="form-control"
                          id="codebarista-revocation-comment"
                          name="comment"
                          rows="5"
                          placeholder="{{ 'codebaristaRevocationRequest.commentPlaceholder'|trans|sw_sanitize }}"
                          maxlength="4096"></textarea>
            </div>

            {% block codebarista_revocation_form_captcha %}
                {% sw_include '@Storefront/storefront/component/captcha/base.html.twig' with { additionalClass : 'col-md-12 mt-2' } %}
            {% endblock %}

            <div class="form-group col-md-12 cb-revocation-form-privacy">
                <h4>{{ 'general.privacyTitle'|trans|sw_sanitize }}</h4>
                <p>
                    {{ 'general.privacyNotice'|trans({
                        '%privacyUrl%': path('frontend.cms.page', { id: config('core.basicInformation.privacyPage') }),
                        '%tosUrl%': path('frontend.cms.page', { id: config('core.basicInformation.tosPage') })
                    })|raw }}
                </p>
            </div>

            <div class="form-group col-md-12 cb-revocation-form-buttons">
                <button type="submit" class="btn btn-primary">
                    {{ 'codebaristaRevocationRequest.formSubmit'|trans|sw_sanitize }}
                </button>
                <input type="submit" class="submit--hidden d-none" tabindex="-1" aria-hidden="true">
            </div>

            <div class="form-group col-md-12">
                <small class="text-muted">
                    {{ 'codebaristaRevocationRequest.requiredFieldsInfo'|trans|sw_sanitize }}
                </small>
            </div>
        </div>
    </form>
</div>
{% endblock %}
